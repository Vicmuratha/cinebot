# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── Required ──────────────────────────────────────────
# Get your key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# ── Optional ──────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Use * only during development. Set your real domain in production.
ALLOWED_ORIGINS=https://yourdomain.com

# Set to 1 only during local development
FLASK_DEBUG=0

# Secret key used to sign Flask sessions (generate a random string)
SECRET_KEY=change-me-to-a-long-random-string
